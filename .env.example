# Poradnik.PRO – Environment configuration example
# Copy this file to .env.local and fill in your values.
# .env.local is excluded from version control (.gitignore).

# -----------------------------------------------------------------------
# Stripe
# -----------------------------------------------------------------------
# PORADNIK_STRIPE_SECRET_KEY=sk_test_...
# PORADNIK_STRIPE_PUBLISHABLE_KEY=pk_test_...
# PORADNIK_STRIPE_WEBHOOK_SECRET=whsec_...

# -----------------------------------------------------------------------
# AI providers (optional)
# -----------------------------------------------------------------------
# PORADNIK_OPENAI_API_KEY=sk-...
# PORADNIK_OPENAI_MODEL=gpt-4o
# PORADNIK_OPENAI_IMAGE_MODEL=dall-e-3

# -----------------------------------------------------------------------
# Platform feature flags (JSON, overrides WP option)
# -----------------------------------------------------------------------
# PORADNIK_MODULE_FLAGS={"affiliate":true,"ads_marketplace":true,"sponsored":true}

# -----------------------------------------------------------------------
# Analytics
# -----------------------------------------------------------------------
# PORADNIK_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# PORADNIK_GSC_SITE_URL=https://poradnik.pro/
